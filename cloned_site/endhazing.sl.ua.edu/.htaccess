# Serve directory URLs without showing index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+[^/])$ $1/ [R=301,L]
</IfModule>
