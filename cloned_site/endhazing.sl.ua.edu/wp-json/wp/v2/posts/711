s<\/h3>\n\n\n\n<p>Hazing: Calisthenics, Physical Threat; Mental Health Threat<\/p>\n\n<\/div>\n\n<div  >\n\n<h3 class=\"wp-block-heading\">Sanctions<\/h3>\n\n\n\n<ul class=\"wp-block-list\">\n<li>Disciplinary Probation from 11\/15\/2023 to 5\/3\/2025<\/li>\n\n\n\n<li>Interim Measures<\/li>\n\n\n\n<li>Required hazing prevention education for members<\/li>\n\n\n\n<li>Must co-host hazing prevention speaker for entire IFC community in Fall 2024<\/li>\n\n\n\n<li>Facility restrictions<\/li>\n\n\n\n<li>Advisory board and standards board formation<\/li>\n\n\n\n<li>National sanctions<\/li>\n<\/ul>\n\n<\/div>\n<\/div><\/div><\/div>\n<\/div>\n","protected":false},"excerpt":{"rendered":"<p>Fall 2023 Description Sigma Alpha Epsilon members verbally and physically abused a new member which resulted in an injury. New members were made to engage in acts of personal servitude and physical exercises.<\/p>\n","protected":false},"author":2,"featured_media":0,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":{"footnotes":""},"categories":[5],"tags":[],"class_list":["post-711","post","type-post","status-publish","format-standard","hentry","category-5"],"_links":{"self":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/711","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/users\/2"}],"replies":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/comments?post=711"}],"version-history":[{"count":1,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/711\/revisions"}],"predecessor-version":[{"id":712,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/711\/revisions\/712"}],"wp:attachment":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/media?