h3>\n\n\n\n<p>Hazing: Calisthenics, Physical Threat<\/p>\n\n<\/div>\n\n<div  >\n\n<h3 class=\"wp-block-heading\">Sanctions<\/h3>\n\n\n\n<ul class=\"wp-block-list\">\n<li>Disciplinary Probation from 9\/12\/2022 until 12\/16\/2023<\/li>\n\n\n\n<li>Limit to 6 social events for Fall 2022<\/li>\n\n\n\n<li>90% of all members must complete online hazing prevention education module<\/li>\n\n\n\n<li>Required adherence to national new member program<\/li>\n<\/ul>\n\n<\/div>\n<\/div><\/div><\/div>\n<\/div>\n","protected":false},"excerpt":{"rendered":"<p>Fall 2022 Description Kappa Alpha new members were forced to complete physical activities in a bathroom which resulted in an injury.<\/p>\n","protected":false},"author":2,"featured_media":0,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":{"footnotes":""},"categories":[6],"tags":[],"class_list":["post-700","post","type-post","status-publish","format-standard","hentry","category-6"],"_links":{"self":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/700","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/users\/2"}],"replies":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/comments?post=700"}],"version-history":[{"count":2,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/700\/revisions"}],"predecessor-version":[{"id":702,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/posts\/700\/revisions\/702"}],"wp:attachment":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/media?parent=700"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/categories?post=700"},{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/endhazing.s