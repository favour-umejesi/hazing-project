:1} -->\n<h1 class=\"wp-block-heading has-text-align-center\">Parents and Family<\/h1>\n<!-- \/wp:heading -->\n\n<!-- wp:paragraph {\"fontSize\":\"medium\"} -->\n<p class=\"has-medium-font-size\"><strong>It is important to speak with your student about hazing, because hazing can occur within any student group or organization.<\/strong> <\/p>\n<!-- \/wp:paragraph -->\n\n<!-- wp:paragraph {\"fontSize\":\"medium\"} -->\n<p class=\"has-medium-font-size\"><strong>Hazing affects more than just students. Join us in the fight to end hazing.<\/strong><\/p>\n<!-- \/wp:paragraph --><\/div><\/div>\n<!-- \/wp:cover --><\/div><\/div>\n<!-- \/wp:cover -->","sidebar_menu":"main-menu","sidebar":false,"sidebar_type":"select","hero":true,"title_alignment":"left","title_width":"standard","footnotes":""},"class_list":["post-46","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/pages\/46","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/comments?post=46"}],"version-history":[{"count":23,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/pages\/46\/revisions"}],"predecessor-version":[{"id":615,"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/pages\/46\/revisions\/615"}],"wp:attachment":[{"href":"https:\/\/endhazing.sl.ua.edu\/wp-json\/wp\/v2\/media?parent=46"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}